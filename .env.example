# Public Mapbox token (client-side, exposed to browser)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx

# Neon Postgres (server-side)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Single-admin auth
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=generate-with-openssl-rand-base64-32

# Public base URL (used by robots.txt + sitemap.xml)
NEXT_PUBLIC_APP_URL=https://cloudtoterra.land

# Object storage for property photos (Vercel Blob).
# Auto-set when a Blob store is linked to the Vercel project; pull locally with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
# Set to 1 in production to upload photos to Blob; unset/0 falls back to inline base64 (local dev).
NEXT_PUBLIC_BLOB_ENABLED=1
