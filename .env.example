# Public Mapbox token (client-side, exposed to browser)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx

# Neon Postgres (server-side)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Single-admin auth
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=generate-with-openssl-rand-base64-32

# Public base URL (used by robots.txt + sitemap.xml)
NEXT_PUBLIC_APP_URL=https://cloudtoterra.land
